---
// src/components/About.astro
const aboutInfo = {
	title: 'Sobre mí',
	description_general: 'Me especializo en construir soluciones web y multiplataforma con foco en estructura, mantenibilidad y una presentación visual más sólida.',
	intro_second: 'Trabajo con herramientas que me permiten prototipar, desarrollar y entregar proyectos con una base técnica consistente.',
	lenguajes: ['JavaScript', 'Java', 'HTML/CSS', 'SQL', 'Bash/Shell Scripting', 'XML', 'JSON', 'C#'],
	frameworks: ['Vue.js', 'Node.js', 'Astro', 'Spring Boot', 'Django'],
	programs: ['Visual Studio Code', 'IntelliJ IDEA', 'Android Studio', 'Git', 'GitHub', 'Docker', 'AWS', 'Azure', 'Linux', 'Postman', 'MySQL Workbench', 'DBeaver', 'Eclipse', 'Vercel', 'WordPress', 'MongoDB'],
};

// Prioridad: mostrar solo las herramientas más relevantes por defecto
const primaryPrograms = ['Visual Studio Code', 'Git', 'GitHub', 'Docker', 'AWS', 'Linux', 'Postman', 'MongoDB', 'MySQL Workbench', 'Vercel'];
const otherPrograms = aboutInfo.programs.filter((p) => !primaryPrograms.includes(p));

---

<section id="about" class="portfolio-section">
	<div class="section-shell">
		<div class="section-title">
			<div class="section-eyebrow">Perfil</div>
			<h2 class="section-heading">{aboutInfo.title}</h2>
			<p class="section-lead">{aboutInfo.description_general}</p>
		</div>

		<div class="about-grid">
			<div class="about-card about-card-intro">
				<h3>Cómo trabajo</h3>
				<p>{aboutInfo.intro_second}</p>
			</div>

			<div class="about-card">
				<h3>Lenguajes</h3>
				<div class="skills-grid">
					{aboutInfo.lenguajes.map((language) => <div class="skill-item">{language}</div>)}
				</div>
			</div>

			<div class="about-card">
				<h3>Frameworks</h3>
				<div class="skills-grid">
					{aboutInfo.frameworks.map((framework) => <div class="skill-item">{framework}</div>)}
				</div>
			</div>

			<div class="about-card about-card-tools">
				<h3>Herramientas</h3>
				<div class="skills-grid">
					{primaryPrograms.map((program) => <div class="skill-item">{program}</div>)}
				</div>

				{otherPrograms.length > 0 && (
					<details class="other-tools">
						<summary>Mostrar más</summary>
						<div class="skills-grid other-grid">
							{otherPrograms.map((program) => <div class="skill-item">{program}</div>)}
						</div>
					</details>
				)}

			</div>
		</div>
	</div>
</section>

<style>
	#about {
		padding-top: 0.5rem;
	}

	.about-grid {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.about-card {
		grid-column: span 6;
		padding: 1.5rem;
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(155, 124, 255, 0.16);
		transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
	}

	.about-card:hover {
		transform: translateY(-3px);
		border-color: rgba(155, 124, 255, 0.3);
		box-shadow: 0 18px 40px rgba(4, 2, 12, 0.28);
	}

	.about-card-intro {
		grid-column: span 12;
		background: linear-gradient(135deg, rgba(155, 124, 255, 0.1), rgba(255, 255, 255, 0.03));
	}

	.about-card-tools {
		grid-column: 1 / -1;
	}

	.about-card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.95rem;
		color: #ffffff;
	}

	.about-card p {
		font-size: 1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.72);
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
		gap: 1rem;
		justify-content: center;
		margin: 0 auto;
		width: 100%;
		max-width: 800px;
	}

	.skill-item {
		background: rgba(255, 255, 255, 0.05);
		color: #ffffff;
		padding: 0.95rem 1rem;
		border-radius: 10px;
		text-align: center;
		font-weight: 500;
		font-size: 0.95rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 45px;
	}

	.skill-item::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(155, 124, 255, 0.2), transparent);
		transition: left 0.5s ease;
	}

	.skill-item:hover::before {
		left: 100%;
	}

	.skill-item:hover {
		transform: translateY(-4px);
		background: rgba(155, 124, 255, 0.15);
		border-color: rgba(155, 124, 255, 0.4);
		box-shadow: 0 4px 20px rgba(155, 124, 255, 0.2);
	}

	@media (max-width: 768px) {
		.about-card {
			grid-column: span 12;
		}

		.skills-grid {
			gap: 0.75rem;
			grid-template-columns: repeat(2, minmax(130px, 150px));
		}

		.skill-item {
			min-height: 40px;
			padding: 0.75rem 0.75rem;
			font-size: 0.9rem;
		}
	}

	/* Styles for the 'Mostrar más' details */
	details.other-tools {
		margin-top: 1rem;
	}

	details.other-tools summary {
		cursor: pointer;
		list-style: none;
		padding: 0.5rem 0;
		color: rgba(255,255,255,0.9);
		font-weight: 600;
	}

	details.other-tools summary::-webkit-details-marker { display:none; }

	.other-grid {
		margin-top: 0.75rem;
	}
</style>
