---
const personalInfo = {
	name: 'Nixon Bolivar Cruz Hidalgo',
	title: 'Desarrollador de aplicaciones multiplataforma',
	description:
		'Desarrollador con experiencia en proyectos web y multiplataforma.',
	cta: {
		primary: 'Ver proyectos',
		secondary: 'Contactar',
	},
	highlights: ['Java','Python', 'JavaScript', 'C#', 'SQL', 'AWS', 'Docker'],
};
---

<section id="presentacion" class="portfolio-section hero-section">
	<div class="section-shell hero-shell">
		<div class="hero-grid">
			<div class="hero-copy">
				<div class="section-eyebrow">Portfolio profesional</div>
				<h1>
					Hola, soy <span class="highlight">{personalInfo.name}</span>
				</h1>
				<p class="hero-title">{personalInfo.title}</p>
				<p class="hero-description">{personalInfo.description}</p>
				<div class="hero-buttons">
					<a href="#projects" class="btn btn-primary">
						{personalInfo.cta.primary}
					</a>
					<a href="#contact" class="btn btn-secondary">
						{personalInfo.cta.secondary}
					</a>
				</div>
			</div>

			<div class="hero-panel">
				<div class="panel-badge">Disponible para nuevos proyectos</div>
				<h2>Enfoque</h2>
				<p>
					Construyo interfaces limpias, estructura sólida y una base técnica consistente para cada proyecto.
				</p>
				<div class="highlight-grid">
					{personalInfo.highlights.map((item) => <span class="highlight-pill">{item}</span>)}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	#presentacion {
		padding-top: 1.5rem;
	}

	.hero-shell {
		padding-block: clamp(2.5rem, 5vw, 4rem);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
		gap: clamp(1.5rem, 3vw, 2.5rem);
		align-items: center;
	}

	.hero-copy {
		max-width: 760px;
	}

	h1 {
		font-size: clamp(2.8rem, 6vw, 5rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
		color: #ffffff;
		margin-bottom: 1rem;
	}

	.highlight {
		background: linear-gradient(90deg, #9B7CFF 0%, #FF70B8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-title {
		font-size: clamp(1.2rem, 2.2vw, 1.55rem);
		font-weight: 600;
		color: rgba(255, 255, 255, 0.88);
		margin-bottom: 1rem;
	}

	.hero-description {
		font-size: 1.06rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.72);
		max-width: 620px;
		margin-bottom: 2rem;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		padding: 1rem 1.6rem;
		border-radius: 14px;
		font-weight: 700;
		font-size: 0.98rem;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
		letter-spacing: 0.02em;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: linear-gradient(135deg, #7b61ff 0%, #ff5ec4 100%);
		color: #ffffff;
		box-shadow: 0 14px 30px rgba(123, 97, 255, 0.28);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(155, 124, 255, 0.35);
		color: rgba(255, 255, 255, 0.95);
	}

	.hero-panel {
		padding: 1.5rem;
		border-radius: 22px;
		background: linear-gradient(180deg, rgba(155, 124, 255, 0.12), rgba(255, 255, 255, 0.03));
		border: 1px solid rgba(155, 124, 255, 0.24);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	.panel-badge {
		display: inline-flex;
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		background: rgba(155, 124, 255, 0.12);
		border: 1px solid rgba(155, 124, 255, 0.22);
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 1rem;
	}

	.hero-panel h2 {
		font-size: 1.5rem;
		color: #ffffff;
		margin-bottom: 0.75rem;
	}

	.hero-panel p {
		font-size: 0.98rem;
		line-height: 1.75;
		color: rgba(255, 255, 255, 0.72);
		margin-bottom: 1.2rem;
	}

	.highlight-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.highlight-pill {
		padding: 0.65rem 0.9rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(155, 124, 255, 0.18);
		color: rgba(255, 255, 255, 0.88);
		font-size: 0.9rem;
		font-weight: 600;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 45px;
	}

	.highlight-pill::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(155, 124, 255, 0.2), transparent);
		transition: left 0.5s ease;
	}

	.highlight-pill:hover::before {
		left: 100%;
	}

	.highlight-pill:hover {
		transform: translateY(-4px);
		background: rgba(155, 124, 255, 0.15);
		border-color: rgba(155, 124, 255, 0.4);
		box-shadow: 0 4px 20px rgba(155, 124, 255, 0.2);
	}

	@media (max-width: 860px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}

		.hero-panel {
			order: -1;
		}
	}

	@media (max-width: 768px) {
		#presentacion {
			padding-top: 1rem;
		}

		.hero-shell {
			padding-block: 2rem;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.btn {
			width: 100%;
			text-align: center;
		}
	}
</style>