---
// src/components/Resume.astro
const resumeData = {
	title: 'Currículum Vitae',
	fullName: 'Nixon Cruz',
	position: 'Desarrollador Multiplataforma',
	summary: 'Desarrollador con experiencia en soluciones web y aplicaciones multiplataforma. Me especializo en crear sistemas escalables con buenas prácticas de desarrollo.',
	
	experience: [
		{
			title: 'Desarrollador Full Stack',
			company: 'Tu Empresa',
			period: '2023 - Presente',
			description: 'Desarrollo de aplicaciones web y APIs. Trabajo con Vue.js, Node.js y bases de datos SQL.'
		},
		{
			title: 'Desarrollador Junior',
			company: 'Otra Empresa',
			period: '2022 - 2023',
			description: 'Participé en proyectos de frontend y backend. Mantenimiento de código existente y nuevas features.'
		}
	],
	
	education: [
		{
			degree: 'Técnico en Desarrollo de Software',
			institution: 'Tu Instituto',
			year: '2022'
		},
		{
			degree: 'Certificación: Vue.js Developer',
			institution: 'Plataforma Online',
			year: '2023'
		}
	],
	
	skills: {
		frontend: ['Vue.js', 'Astro', 'HTML/CSS', 'JavaScript'],
		backend: ['Node.js', 'Java', 'Spring Boot', 'Django', 'MongoDB', 'SQL'],
		tools: ['Git', 'Docker', 'AWS', 'Linux']
	}
};
---

<section id="resume" class="portfolio-section">
	<div class="section-shell">
		<div class="section-title">
			<div class="section-eyebrow">Perfil</div>
			<h2 class="section-heading">{resumeData.title}</h2>
			<p class="section-lead">{resumeData.summary}</p>
		</div>

		<div class="resume-container">
			<!-- Header -->
			<div class="resume-header">
				<div class="resume-header-content">
					<h1>{resumeData.fullName}</h1>
					<p class="resume-position">{resumeData.position}</p>
				</div>
				<button class="btn-download" onclick="window.open('https://drive.google.com/file/d/1rssn6W_VZ1qvLh04bXbwxoJX4GhrENgY/view?usp=drive_link', '_blank')">
					<span>Descargar CV</span>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
						<polyline points="7 10 12 15 17 10"></polyline>
						<line x1="12" y1="15" x2="12" y2="3"></line>
					</svg>
				</button>
			</div>

			<!-- Experience -->
			<div class="resume-section">
				<h3 class="resume-section-title">Experiencia Laboral</h3>
				<div class="resume-entries">
					{resumeData.experience.map((job) => (
						<div class="resume-entry">
							<div class="entry-header">
								<div>
									<h4>{job.title}</h4>
									<p class="entry-company">{job.company}</p>
								</div>
								<span class="entry-period">{job.period}</span>
							</div>
							<p class="entry-description">{job.description}</p>
						</div>
					))}
				</div>
			</div>

			<!-- Education -->
			<div class="resume-section">
				<h3 class="resume-section-title">Formación Académica</h3>
				<div class="resume-entries">
					{resumeData.education.map((edu) => (
						<div class="resume-entry">
							<div class="entry-header">
								<div>
									<h4>{edu.degree}</h4>
									<p class="entry-company">{edu.institution}</p>
								</div>
								<span class="entry-period">{edu.year}</span>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Skills -->
			<div class="resume-section">
				<h3 class="resume-section-title">Competencias Técnicas</h3>
				<div class="resume-skills">
					<div class="skill-category">
						<h5>Frontend</h5>
						<div class="skill-tags">
							{resumeData.skills.frontend.map((skill) => <span class="skill-tag">{skill}</span>)}
						</div>
					</div>
					<div class="skill-category">
						<h5>Backend</h5>
						<div class="skill-tags">
							{resumeData.skills.backend.map((skill) => <span class="skill-tag">{skill}</span>)}
						</div>
					</div>
					<div class="skill-category">
						<h5>Herramientas</h5>
						<div class="skill-tags">
							{resumeData.skills.tools.map((skill) => <span class="skill-tag">{skill}</span>)}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	#resume {
		padding-top: 0.5rem;
	}

	.resume-container {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.resume-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		padding: 2rem;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.resume-header-content h1 {
		font-size: 2rem;
		margin: 0 0 0.5rem 0;
		color: #ffffff;
	}

	.resume-position {
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.7);
		margin: 0;
	}

	.btn-download {
		background: linear-gradient(135deg, #333333 0%, #1a1a1a 100%);
		color: white;
		border: none;
		padding: 0.9rem 1.8rem;
		border-radius: 10px;
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		transition: all 0.3s ease;
		white-space: nowrap;
	}

	.btn-download:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
	}

	.resume-section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.resume-section-title {
		font-size: 1.4rem;
		color: #ffffff;
		margin: 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid rgba(255, 255, 255, 0.2);
	}

	.resume-entries {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.resume-entry {
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		transition: all 0.3s ease;
	}

	.resume-entry:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.15);
	}

	.entry-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 0.75rem;
		gap: 1rem;
	}

	.resume-entry h4 {
		font-size: 1.1rem;
		color: #ffffff;
		margin: 0 0 0.25rem 0;
	}

	.entry-company {
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.7);
		margin: 0;
		font-weight: 500;
	}

	.entry-period {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.5);
		white-space: nowrap;
	}

	.entry-description {
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.7);
		margin: 0;
	}

	.resume-skills {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}

	.skill-category h5 {
		font-size: 1rem;
		color: #ffffff;
		margin: 0 0 0.75rem 0;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.skill-tag {
		background: rgba(255, 255, 255, 0.08);
		color: #ffffff;
		padding: 0.5rem 1rem;
		border-radius: 20px;
		font-size: 0.9rem;
		font-weight: 500;
		border: 1px solid rgba(255, 255, 255, 0.15);
		transition: all 0.3s ease;
	}

	.skill-tag:hover {
		background: rgba(255, 255, 255, 0.15);
		border-color: rgba(255, 255, 255, 0.3);
		transform: translateY(-2px);
	}

	@media (max-width: 768px) {
		.resume-header {
			flex-direction: column;
			gap: 1.5rem;
		}

		.btn-download {
			width: 100%;
			justify-content: center;
		}

		.resume-header-content h1 {
			font-size: 1.5rem;
		}

		.resume-section-title {
			font-size: 1.1rem;
		}

		.resume-skills {
			grid-template-columns: 1fr;
		}
	}
</style>