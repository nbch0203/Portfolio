---
// src/components/Contact.astro
const contactInfo = {
  title: "Contacto",
  description:
    "Estoy disponible para nuevas oportunidades.",
  // Nota: email no se expone aquí por privacidad; se gestiona desde el servidor vía env
  social: [
    {
      name: "GitHub",
      url: "https://github.com/nbch0203",
      icon: "github",
    },
    {
      name: "LinkedIn",
      url: "https://www.linkedin.com/in/nixon-bolivar-cruz-hidalgo-19a078268/",
      icon: "linkedin",
    },
  ],
};
---

<section id="contact" class="portfolio-section">
  <div class="section-shell">
    <div class="section-title">
      <div class="section-eyebrow">Contacto</div>
      <h2 class="section-heading">{contactInfo.title}</h2>
      <p class="section-lead">{contactInfo.description}</p>
    </div>

    <div class="contact-content">
      <div class="contact-hero">
        <!-- <form id="contact-form" class="contact-form" novalidate >
					<div class="contact-form-inner">
						<div class="contact-kicker">Hablemos</div>
						<h3>¿Tienes una idea, colaboración o vacante?</h3>
						<p>Cuéntame brevemente sobre tu proyecto y te responderé con los siguientes pasos.</p>

						<label class="form-row">
							<span class="form-label">Nombre *</span>
							<input name="name" type="text" class="form-input" placeholder="Tu nombre" required disabled />
						</label>

						<label class="form-row">
							<span class="form-label">Correo</span>
							<input name="email" type="email" class="form-input" placeholder="tu@correo.com" disabled />
						</label>

						<label class="form-row">
							<span class="form-label">Asunto</span>
							<input name="subject" type="text" class="form-input" placeholder="Breve asunto" disabled />
						</label>

						<label class="form-row">
							<span class="form-label">Mensaje *</span>
							<textarea name="message" rows="6" class="form-input form-textarea" placeholder="Describe tu proyecto o consulta" required disabled></textarea>
						</label>

						<div class="form-actions">
							<button type="submit" class="btn-submit" disabled>Enviar mensaje</button>
							<span class="form-feedback" aria-live="polite" style="margin-left:0.75rem;color:rgba(255,255,255,0.85)"></span>
						</div>
					</div>
