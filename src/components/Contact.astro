<style>
  #contact {
    padding-top: 0.5rem;
  }

  .contact-content {
    display: grid;
    gap: 1.25rem;
  }

  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1rem;
    align-items: stretch;
  }

  .contact-hero-copy,
  .contact-email-card,
  .social-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(155, 124, 255, 0.16);
    border-radius: 20px;
    padding: 1.5rem;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .contact-hero-copy:hover,
  .contact-email-card:hover,
  .social-section:hover {
    transform: translateY(-3px);
    border-color: rgba(155, 124, 255, 0.3);
    box-shadow: 0 18px 40px rgba(4, 2, 12, 0.28);
  }

  .contact-hero-copy {
    background: linear-gradient(
      135deg,
      rgba(155, 124, 255, 0.1),
      rgba(255, 255, 255, 0.03)
    );
    display: grid;
    align-content: start;
    gap: 0.85rem;
  }

  .contact-kicker {
    display: inline-flex;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(155, 124, 255, 0.12);
    border: 1px solid rgba(155, 124, 255, 0.22);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-hero-copy h3 {
    font-size: clamp(1.4rem, 2vw, 2rem);
    color: #ffffff;
    line-height: 1.2;
  }

  .contact-hero-copy p {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.8;
  }

  .contact-email-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(
      135deg,
      rgba(155, 124, 255, 0.14),
      rgba(255, 112, 184, 0.06)
    );
  }

  .contact-email-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at top right,
      rgba(255, 112, 184, 0.14),
      transparent 34%
    );
    opacity: 0.7;
  }

  .contact-email-card,
  .social-section {
    position: relative;
  }

  .email-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(
      135deg,
      rgba(155, 124, 255, 0.12),
      rgba(255, 255, 255, 0.03)
    );
    border: 1px solid rgba(155, 124, 255, 0.24);
    padding: 1.5rem;
    border-radius: 20px;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
    position: relative;
  }

  .email-card:hover {
    transform: translateY(-3px);
    border-color: rgba(155, 124, 255, 0.35);
    box-shadow: 0 18px 40px rgba(4, 2, 12, 0.28);
  }

  .email-icon {
    font-size: 2.5rem;
    filter: drop-shadow(0 4px 8px rgba(155, 124, 255, 0.3));
    flex-shrink: 0;
  }

  .email-copy {
    display: grid;
    gap: 0.4rem;
  }

  .email-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.58);
    font-weight: 700;
  }

  .email-link {
    font-size: 1.25rem;
    font-weight: 600;
    color: #9b7cff;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .email-link:hover {
    color: #ff70b8;
    transform: scale(1.05);
  }

  .email-note {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.64);
  }

  .social-section {
    padding: 1.5rem;
  }

  .social-title {
    font-size: 1.2rem;
    margin-bottom: 0.45rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.95);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .social-lead {
    margin-bottom: 1.1rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  /* Form styles */
  .contact-form {
    background: linear-gradient(
      135deg,
      rgba(155, 124, 255, 0.06),
      rgba(255, 255, 255, 0.02)
    );
    border: 1px solid rgba(155, 124, 255, 0.12);
    border-radius: 20px;
    padding: 1.25rem;
    display: grid;
  }

  .contact-form .contact-form-inner {
    gap: 0.75rem;
    display: grid;
  }
  .contact-form .form-row {
    display: grid;
    gap: 0.45rem;
  }
  .contact-form .form-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
  }
  .contact-form .form-input {
    padding: 0.6rem 0.8rem;
    border-radius: 10px;
    border: 1px solid rgba(155, 124, 255, 0.08);
    background: rgba(0, 0, 0, 0.22);
    color: rgba(255, 255, 255, 0.95);
  }
  .contact-form .form-textarea {
    min-height: 110px;
    resize: vertical;
  }
  .form-actions {
    margin-top: 0.25rem;
    display: flex;
    align-items: center;
  }
  .btn-submit {
    background: linear-gradient(90deg, #9b7cff, #ff70b8);
    color: #fff;
    border: none;
    padding: 0.65rem 0.95rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(155, 124, 255, 0.14);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.4rem;
    background: rgba(155, 124, 255, 0.08);
    border: 1px solid rgba(155, 124, 255, 0.25);
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .social-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(155, 124, 255, 0.15),
      transparent
    );
    transition: left 0.5s ease;
  }

  .social-link:hover::before {
    left: 100%;
  }

  .social-link:hover {
    background: rgba(155, 124, 255, 0.15);
    border-color: rgba(155, 124, 255, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(155, 124, 255, 0.25);
  }

  .social-icon {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(155, 124, 255, 0.16);
    border: 1px solid rgba(155, 124, 255, 0.25);
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .social-link:hover .social-icon {
    transform: scale(1.2) rotate(5deg);
  }

  .social-name {
    flex: 1;
    font-size: 1.05rem;
  }

  .arrow {
    font-size: 1.25rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .social-link:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .contact-hero {
      grid-template-columns: 1fr;
    }

    .contact-content {
      gap: 1rem;
    }

    .social-grid {
      grid-template-columns: 1fr;
    }

    .contact-email-card {
      align-items: flex-start;
    }

    .email-link {
      font-size: 1.05rem;
      word-break: break-word;
    }

    .contact-hero-copy,
    .contact-email-card,
    .social-section {
      padding: 1.25rem;
    }

    .social-link {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
