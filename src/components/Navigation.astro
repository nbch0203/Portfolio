---
// src/components/Navigation.astro

interface Props {
	currentPage?: 'home' | 'resume';
}

const { currentPage = 'home' } = Astro.props;

const navLinks = [
	{ label: 'Inicio', href: '/#presentacion', section: 'presentacion' },
	{ label: 'About', href: '/#about', section: 'about' },
	{ label: 'Proyectos', href: '/#projects', section: 'projects' },
	{ label: 'Contacto', href: '/#contact', section: 'contact' },
   // { label: 'CV', href: '/resume', section: 'resume' },

];
---

<nav class="navegacion">
	<div class="nav-container">
		<div class="nav-brand">
			<a href="/">
				<div class="nav-logo">Nixon Cruz</div>
				<span>Desarrollador multiplataforma</span>
			</a>
		</div>
		<div class="nav-links">
			{navLinks.map((link) => {
				const isActive = currentPage === 'resume' && link.section === 'resume';
				const isCVLink = link.section === 'resume';
				return (
					<a 
						href={link.href} 
						data-section={link.section}
						class={isActive ? 'active' : isCVLink ? '' : 'nav-section-link'}
					>
						{link.label}
					</a>
				);
			})}
		</div>
	</div>
</nav>

<style>
	.navegacion {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(26, 11, 46, 0.85);
		backdrop-filter: blur(20px) saturate(180%);
		border-bottom: 1px solid rgba(155, 124, 255, 0.18);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
		transition: all 0.3s ease;
	}

	.nav-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 1rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-brand {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.nav-brand a {
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.nav-logo {
		font-size: 1.5rem;
		font-weight: 700;
		background: linear-gradient(90deg, #9B7CFF 0%, #FF70B8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.5px;
		margin: 0;
	}

	.nav-brand span {
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.58);
	}

	.nav-links {
		display: flex;
		gap: 2.5rem;
		align-items: center;
		padding: 0.45rem 0.75rem;
		border: 1px solid rgba(155, 124, 255, 0.12);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
	}

	.nav-links a {
		text-decoration: none;
		color: rgba(255, 255, 255, 0.85);
		font-weight: 500;
		font-size: 0.95rem;
		position: relative;
		transition: color 0.3s ease;
		padding: 0.45rem 0.2rem;
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #9B7CFF 0%, #FF70B8 100%);
		transition: width 0.3s ease;
	}

	.nav-links a:hover {
		color: #ffffff;
	}

	.nav-links a:hover::after {
		width: 100%;
	}

	.nav-links a.active {
		color: #ffffff;
	}

	.nav-links a.active::after {
		width: 100%;
	}

	@media (max-width: 768px) {
		.nav-container {
			padding: 0.75rem 1rem;
			flex-direction: column;
			gap: 1rem;
		}

		.nav-brand {
			align-items: center;
		}

		.nav-brand a {
			align-items: center;
			text-align: center;
		}

		.nav-links {
			gap: 1.5rem;
			flex-wrap: wrap;
			justify-content: center;
			border-radius: 18px;
		}

		.nav-links a {
			font-size: 0.85rem;
		}
	}
</style>
