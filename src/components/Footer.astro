---
// src/components/Footer.astro

const currentYear = new Date().getFullYear();

const socialLinks = [
	{ name: 'GitHub', url: 'https://github.com', icon: 'github' },
	{ name: 'LinkedIn', url: 'https://linkedin.com', icon: 'linkedin' },
	{ name: 'Twitter', url: 'https://twitter.com', icon: 'twitter' },
];

const footerLinks = [
	{ label: 'Inicio', href: '/' },
	{ label: 'About', href: '/#about' },
	{ label: 'Proyectos', href: '/#projects' },
	{ label: 'CV', href: '/resume' },
	{ label: 'Contacto', href: '/#contact' },
];
---

<footer class="footer">
	<div class="footer-container">
		<!-- Links Section -->
		<div class="footer-content">
			<div class="footer-section">
				<h3>Navegación</h3>
				<ul>
					{footerLinks.map((link) => (
						<li>
							<a href={link.href}>{link.label}</a>
						</li>
					))}
				</ul>
			</div>

			<div class="footer-section footer-contact">
				<h3>Contacto</h3>
				<p class="contact-line">¿Tienes un proyecto?</p>
				<p class="contact-email"><a href="mailto:hello@tuemail.com">hello@tuemail.com</a></p>
				<a class="contact-cta" href="/#contact">Enviar mensaje</a>
			</div>

			<div class="footer-section">
				<h3>Redes Sociales</h3>
				<div class="social-links">
					{socialLinks.map((social) => (
						<a
							href={social.url}
							target="_blank"
							rel="noopener noreferrer"
							class="social-link"
							title={social.name}
						>
							{social.name === 'GitHub' && (
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
								</svg>
							)}
							{social.name === 'LinkedIn' && (
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
									<rect x="2" y="9" width="4" height="12"></rect>
									<circle cx="4" cy="4" r="2"></circle>
								</svg>
							)}
							{social.name === 'Twitter' && (
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2s9 5 20 0a9.5 9.5 0 0 0-9-5.5"></path>
								</svg>
							)}
						</a>
					))}
				</div>
			</div>
		</div>

		<!-- Divider -->
		<div class="footer-divider"></div>

		<!-- Copyright -->
		<div class="footer-bottom">
			<p>&copy; {currentYear} Nixon Cruz. Desarrollador Multiplataforma.</p>
			<p class="footer-credit">Diseño y desarrollo con <span class="heart">♥</span> usando Astro</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: rgba(26, 11, 46, 0.95);
		border-top: 1px solid rgba(155, 124, 255, 0.2);
		padding: 2rem 1.5rem;
		margin-top: 3rem;
	}

	.footer-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
		margin-bottom: 1.25rem;
		align-items: start;
	}

	.footer-section h3 {
		font-size: 1.1rem;
		color: #ffffff;
		margin: 0 0 1rem 0;
		background: linear-gradient(90deg, #9B7CFF 0%, #FF70B8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.footer-section ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-section a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		transition: all 0.3s ease;
		font-size: 0.95rem;
	}

	.footer-section a:hover {
		color: #9B7CFF;
		padding-left: 0.5rem;
	}

	.social-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}

	.social-link {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(155, 124, 255, 0.15);
		border-radius: 10px;
		color: #9B7CFF;
		transition: all 0.3s ease;
		border: 1px solid rgba(155, 124, 255, 0.2);
	}

	.social-link:hover {
		background: rgba(155, 124, 255, 0.3);
		border-color: rgba(155, 124, 255, 0.4);
		transform: translateY(-3px);
	}

	.social-link svg {
		stroke: currentColor;
	}

	.footer-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(155, 124, 255, 0.3), transparent);
		margin: 1rem 0;
	}

	.footer-bottom {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: 0.5rem;
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.7);
	}

	.footer-credit {
		font-size: 0.85rem !important;
	}

	.heart {
		color: #FF70B8;
		animation: heartbeat 1.5s ease-in-out infinite;
	}

	@keyframes heartbeat {
		0%, 100% {
			opacity: 1;
			transform: scale(1);
		}
		50% {
			opacity: 0.8;
			transform: scale(1.1);
		}
	}

	@media (max-width: 768px) {
		.footer {
			padding: 2rem 1.5rem;
			margin-top: 2rem;
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.footer-section ul {
			flex-direction: row;
			flex-wrap: wrap;
		}


		.footer-bottom {
			flex-direction: column;
			gap: 0.25rem;
			text-align: center;
		}

		.footer-bottom p {
			font-size: 0.85rem;
		}
	}

	/* Contact */
	.footer-contact .contact-line {
		color: rgba(255,255,255,0.9);
		margin: 0 0 0.25rem 0;
	}

	.footer-contact .contact-email a {
		color: rgba(255,255,255,0.85);
		text-decoration: underline;
	}

	.contact-cta {
		display: inline-block;
		margin-top: 0.5rem;
		padding: 0.5rem 0.9rem;
		background: linear-gradient(90deg, #9B7CFF 0%, #FF70B8 100%);
		color: #fff;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		box-shadow: 0 6px 18px rgba(155,124,255,0.12);
		transition: transform 0.18s ease, box-shadow 0.18s ease;
	}

	.contact-cta:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 24px rgba(155,124,255,0.18);
	}
</style>
