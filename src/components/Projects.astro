---
const projects = [
  {
    title: "Repositorio DAM",
    description:
      "Repositorio académico con ejercicios y prácticas de desarrollo multiplataforma, organizado para demostrar crecimiento técnico y variedad de tecnologías.",
	status: "Terminado",
    image: "/repositorioDAM.webp",
    link: "https://github.com/nbch0203/DAM",
    featured: "Proyecto académico",
    tags: [
      "Java",
      "HTML",
      "CSS",
      "JavaScript",
      "MySQL",
      "Android",
      "C#",
      "WPF",
      "AWS",
      "SQLite",
    ],
  },
  {
    title: "Portafolio Personal",
    description:
      "Portfolio personal desarrollado con Astro para comunicar experiencia, proyectos y enfoque visual de una forma más profesional.",
	status: "Terminado",
    image: "/imagenPortfolio.webp",
    link: "https://github.com/nbch0203/Portfolio",
    featured: "Sitio principal",
    tags: ["Astro", "JavaScript", "CSS", "HTML"],
  },
  {
    title: "App de Cine",
    description:
      "Aplicación de escritorio orientada a la gestión de un cine, con reservas, carteleras y administración de usuarios.",
	status: "Terminado",
    image: "/appCine.webp",
    link: "https://github.com/nbch0203/App-de-cine",
    featured: "Aplicación de escritorio",
    tags: ["C#", "WPF", "MySQL", "AWS"],
  },
  {
    title: "Trabajo Intermodular",
    description:
      "Trabajo de final de mi grado superior de desarrollo de aplicaciones multiplataforma (DAM)",
	status: "Terminado",
    image: "/schoolSafeTrack.webp",
    link: "https://github.com/nbch0203/TFG-DAM",
    featured: "Proyecto académico",
    tags: ["Vue.js", "JavaScript", "CSS", "HTML", "OpenStreetmap", "Java",'AWS','MySQL','Docker'],
  },
  {
    title: "App para repartidores",
    description:
      "Proyecto personal de una app para organización de paradas para repartidores",
    status: "En proceso",
	image: "/smartRoute.webp",
    link: "https://github.com/nbch0203/App-para-Repartidores",
    featured: "Proyecto personal",
    tags: ["Java", "OpenStreetmap"],
  },
];
---

<section id="projects" class="portfolio-section">
  <div class="section-shell">
    <div class="section-title">
      <div class="section-eyebrow">Proyectos</div>
      <h2 class="section-heading">Trabajos seleccionados</h2>
      <p class="section-lead">
       Todos mis proyectos desarrollados a lo largo de mi formación y experiencia profesional.
		</p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project, index) => (
          <article class="project-card">
            <div
              class={`project-image ${project.status === "En proceso" ? "project-image--in-progress" : ""}`}
            >
              <img
                src={project.image}
                alt={
                  project.status === "En proceso"
                    ? `${project.title} en desarrollo`
                    : project.title
                }
              />
            </div>

            <div class="project-content">
              <div class="project-meta">
                <span class="project-index">0{index + 1}</span>
                <span class="project-chip">{project.featured}</span>
              </div>

              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
			  {project.status === "En proceso" && (
                <p class="project-note">
                  Abierto para consultar el avance actual y la evolución del proyecto.
                </p>
              )}
              <a
                href={project.link}
                class="project-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Ver repositorio
                <span>→</span>
              </a>
              
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  #projects {
    padding-top: 0.5rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 22px;
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
  }

  .project-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
  }

  .project-card:has(.project-image--in-progress):hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .project-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    position: relative;
    background: rgba(255, 255, 255, 0.04);
  }

  .project-image--in-progress {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(0, 0, 0, 0.15));
  }

  .project-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.2));
    pointer-events: none;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    transition: transform 0.35s ease, filter 0.35s ease, opacity 0.35s ease;
  }

  .project-image--in-progress img {
    opacity: 1;
    filter: saturate(1) contrast(1);
  }

  .project-card:has(.project-image--in-progress):hover .project-image img {
    opacity: 0.4;
    filter: blur(2px);
  }

  .project-image--in-progress::before {
    content: "⚙ En desarrollo";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.85);
    color: #ffffff;
    padding: 0.8rem 1.2rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 2;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
  }

  .project-card:has(.project-image--in-progress):hover .project-image--in-progress::before {
    opacity: 1;
  }

  .project-status-flag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(8, 6, 17, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .project-status-strip {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(15, 10, 25, 0.74);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.78rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
  }

  .project-status-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: #ffffff;
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4);
    animation: pulse 1.8s infinite;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-card:has(.project-image--in-progress):hover .project-image img {
    transform: scale(1);
  }

  .project-content {
    padding: 1.4rem;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .project-index {
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.5);
  }

  .project-chip {
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.82);
  }

  .project-content h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
  }

  .project-content p {
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 1.1rem;
    line-height: 1.75;
    font-size: 0.96rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.35rem;
  }

  .tag {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-weight: 500;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
    color: #ffffff;
  }

  .project-link:hover {
    color: #b0b0b0;
    gap: 0.5rem;
  }

  .project-note {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(255, 255, 255, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
    }
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-content {
      padding: 1.2rem;
    }
  }
</style>
