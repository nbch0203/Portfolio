---
const projects = [
	{
		title: 'Repositorio DAM',
		description: 'Repositorio académico con ejercicios y prácticas de desarrollo multiplataforma, organizado para demostrar crecimiento técnico y variedad de tecnologías.',
		image: 'public/imagenes/repositorioDAM.webp',
		link: 'https://github.com/nbch0203/DAM',
		featured: 'Proyecto académico',
		tags: ['Java', 'HTML', 'CSS', 'JavaScript', 'MySQL', 'Android', 'C#', 'WPF', 'AWS', 'SQLite'],
	},
	{
		title: 'Portafolio Personal',
		description: 'Portfolio personal desarrollado con Astro para comunicar experiencia, proyectos y enfoque visual de una forma más profesional.',
		image: 'public/imagenes/imagenPortfolio.webp',
		link: 'https://github.com/nbch0203/Portfolio',
		featured: 'Sitio principal',
		tags: ['Astro', 'JavaScript', 'CSS', 'HTML'],
	},
	{
		title: 'App de Cine',
		description: 'Aplicación de escritorio orientada a la gestión de un cine, con reservas, carteleras y administración de usuarios.',
		image: 'public/imagenes/appCine.webp',
		link: 'https://github.com/nbch0203/App-de-cine',
		featured: 'Aplicación de escritorio',
		tags: ['C#', 'WPF', 'MySQL', 'AWS'],
	},
];
---

<section id="projects" class="portfolio-section">
	<div class="section-shell">
		<div class="section-title">
			<div class="section-eyebrow">Proyectos</div>
			<h2 class="section-heading">Trabajos seleccionados</h2>
			<p class="section-lead">Una selección de proyectos que muestran mi evolución técnica, atención al detalle y capacidad para integrar diseño con funcionalidad.</p>
		</div>

		<div class="projects-grid">
			{projects.map((project, index) => (
				<article class="project-card">
					<div class="project-image">
						<img src={project.image} alt={project.title} />
					</div>
					<div class="project-content">
						<div class="project-meta">
							<span class="project-index">0{index + 1}</span>
							<span class="project-chip">{project.featured}</span>
						</div>
						<h3>{project.title}</h3>
						<p>{project.description}</p>
						<div class="project-tags">
							{project.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
						<a href={project.link} class="project-link" target="_blank" rel="noopener noreferrer">
							Ver proyecto
							<span>→</span>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	#projects {
		padding-top: 0.5rem;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.25rem;
	}

	.project-card {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(155, 124, 255, 0.18);
		border-radius: 22px;
		overflow: hidden;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
		box-shadow: 0 12px 30px rgba(4, 2, 12, 0.22);
	}

	.project-card:hover {
		transform: translateY(-5px);
		border-color: rgba(155, 124, 255, 0.35);
		box-shadow: 0 18px 50px rgba(4, 2, 12, 0.34);
	}

	.project-image {
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		position: relative;
		background: rgba(255, 255, 255, 0.04);
	}

	.project-image::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent, rgba(10, 6, 17, 0.3));
	}

	.project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.project-card:hover .project-image img {
		transform: scale(1.05);
	}

	.project-content {
		padding: 1.4rem;
	}

	.project-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.project-index {
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: rgba(255, 255, 255, 0.5);
	}

	.project-chip {
		font-size: 0.78rem;
		font-weight: 700;
		padding: 0.4rem 0.7rem;
		border-radius: 999px;
		background: rgba(155, 124, 255, 0.12);
		border: 1px solid rgba(155, 124, 255, 0.2);
		color: rgba(255, 255, 255, 0.82);
	}

	.project-content h3 {
		font-size: 1.35rem;
		margin-bottom: 0.75rem;
		color: #ffffff;
	}

	.project-content p {
		color: rgba(255, 255, 255, 0.72);
		margin-bottom: 1.1rem;
		line-height: 1.75;
		font-size: 0.96rem;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.35rem;
	}

	.tag {
		background: rgba(155, 124, 255, 0.12);
		padding: 0.4rem 0.75rem;
		border-radius: 999px;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(155, 124, 255, 0.22);
		font-weight: 500;
	}

	.project-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-weight: 700;
		color: #9B7CFF;
	}

	.project-link:hover {
		color: #FF70B8;
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}

		.project-content {
			padding: 1.2rem;
		}
	}
</style>