---
// src/layouts/Layout.astro
const {
	title = 'Portfolio Nixon Cruz',
	description = 'Portfolio profesional de Nixon Cruz, desarrollador de aplicaciones multiplataforma.',
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#11071f" />
		<title>{title}</title>
    <slot name="head" />
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
	/* Variables CSS */
	:root {
		--color-primary: #9333ea;
		--color-secondary: #bc52ee;
		--color-accent: #ff70b8;
		--color-text: #ffffff;
		--color-text-light: #e2e2e2;
		--color-background: #0f061b;
		--color-surface: rgba(16, 9, 30, 0.72);
		--color-surface-strong: rgba(22, 11, 42, 0.88);
		--color-section-border: rgba(155, 124, 255, 0.18);
		--color-section-border-strong: rgba(155, 124, 255, 0.3);
		--shadow-elevated: 0 22px 60px rgba(4, 2, 12, 0.45);
		--radius-section: 28px;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html,
	body {
		width: 100%;
		height: 100%;
		font-family: Inter, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		color: var(--color-text);
	}

	body {
		background: 
			radial-gradient(circle at 15% 20%, rgba(155, 124, 255, 0.12), transparent 28%),
			radial-gradient(circle at 85% 15%, rgba(255, 112, 184, 0.08), transparent 24%),
			radial-gradient(circle at 80% 80%, rgba(155, 124, 255, 0.07), transparent 28%),
			linear-gradient(180deg, #100617 0%, #0f061b 45%, #0c0515 100%);
		background-attachment: fixed;
		min-height: 100vh;
		padding-top: 70px;
		overflow-x: hidden;
	}

	body::after {
		content: '';
		position: fixed;
		inset: 0;
		background-image:
			radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.055) 1px, transparent 0);
		background-size: 18px 18px;
		opacity: 0.08;
		pointer-events: none;
		z-index: 0;
	}

	/* Efecto de grano sutil */
	body::before {
		content: '';
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.01) 2px, rgba(255,255,255,0.01) 4px);
		pointer-events: none;
		opacity: 0.2;
		z-index: 1;
	}

	/* Contenido sobre el grano */
	body > * {
		position: relative;
		z-index: 2;
	}

	h1, h2, h3, h4, h5, h6 {
		line-height: 1.2;
		font-weight: 600;
		color: var(--color-secondary);
	}

	p {
		line-height: 1.6;
	}

	a {
		color: var(--color-secondary);
		text-decoration: none;
		transition: all 0.3s ease;
	}

	a:hover {
		opacity: 0.8;
	}

	.portfolio-section {
		padding: 2rem 1.5rem;
	}

	.section-shell {
		max-width: 1240px;
		margin: 0 auto;
		padding: clamp(2rem, 4vw, 3.5rem);
		background: linear-gradient(180deg, rgba(18, 9, 31, 0.9) 0%, rgba(13, 7, 24, 0.82) 100%);
		border: 1px solid var(--color-section-border);
		border-radius: var(--radius-section);
		box-shadow: var(--shadow-elevated);
		backdrop-filter: blur(18px) saturate(140%);
		position: relative;
		overflow: hidden;
	}

	.section-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(155, 124, 255, 0.08), transparent 35%, rgba(255, 112, 184, 0.04));
		pointer-events: none;
	}

	.section-shell > * {
		position: relative;
		z-index: 1;
	}

	.section-title {
		max-width: 760px;
		margin: 0 auto 2.5rem;
		text-align: center;
	}

	.section-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.9rem;
		border-radius: 999px;
		border: 1px solid rgba(155, 124, 255, 0.24);
		background: rgba(155, 124, 255, 0.08);
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}

	.section-heading {
		font-size: clamp(2.2rem, 4vw, 3.4rem);
		color: #ffffff;
		letter-spacing: -0.03em;
		margin-bottom: 0.9rem;
	}

	.section-lead {
		font-size: 1.05rem;
		line-height: 1.75;
		color: rgba(255, 255, 255, 0.72);
	}
</style>