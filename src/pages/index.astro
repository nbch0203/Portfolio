---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import Presentacion from '../components/Presentacion.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

---


<Layout title="Mi Portfolio - Inicio">
	<Navigation currentPage="home" />
	
	<main class="page-content">
		<Presentacion />
		<About />
		<Projects />
		<Contact />
	</main>
	
	<Footer />
</Layout>

<style>
	html {
		scroll-behavior: smooth;
	}

	.page-content {
		display: grid;
		gap: 1rem;
		padding-top: 6rem;
	}
</style>

<script>
	// Intersection Observer para actualizar nav activa según scroll
	const observerOptions = {
		root: null,
		rootMargin: '-50% 0px -50% 0px',
		threshold: 0
	};

	const navLinks = document.querySelectorAll('[data-section]');
	
	const observerCallback = (entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				// Remover active de todos
				navLinks.forEach(link => link.classList.remove('active'));
				
				// Agregar active al link correspondiente
				const activeLink = document.querySelector(`[data-section="${entry.target.id}"]`);
				if (activeLink) {
					activeLink.classList.add('active');
				}
			}
		});
	};

	const observer = new IntersectionObserver(observerCallback, observerOptions);

	// Observar todas las secciones
	const sections = ['presentacion', 'about', 'projects', 'contact'];
	sections.forEach(sectionId => {
		const element = document.getElementById(sectionId);
		if (element) {
			observer.observe(element);
		}
	});
</script>